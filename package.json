{
  "name": "lotta",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:rollback": "tsc -b && vite build --outDir dist-rollback",
    "lint": "biome lint .",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:p2p": "RUN_P2P_E2E=1 playwright test",
    "test:e2e:browserstack": "browserstack-node-sdk playwright test",
    "test:e2e:video": "playwright test && node scripts/concat-videos.mjs",
    "prepare": "husky",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check --write .",
    "knip": "knip",
    "jscpd": "jscpd src/",
    "secretlint": "secretlint '**/*'",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-pwa-assets": "pwa-assets-generator"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["sharp"]
  },
  "lint-staged": {
    "*": ["biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"]
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.167.3",
    "@trystero-p2p/mqtt": "0.23.0",
    "jspdf": "^4.2.1",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sql.js": "^1.14.1",
    "trystero": "^0.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.58.2",
    "@secretlint/core": "^11.4.0",
    "@secretlint/secretlint-rule-preset-recommend": "^11.4.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.10",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.0",
    "browserstack-node-sdk": "^1.50.11",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "jsdom": "^29.0.1",
    "knip": "^6.0.6",
    "lint-staged": "^16.4.0",
    "msw": "^2.13.2",
    "secretlint": "^11.4.0",
    "semantic-release": "^25.0.3",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-static-copy": "^4.0.0",
    "vitest": "^4.1.2",
    "workbox-window": "^7.4.0"
  }
}
